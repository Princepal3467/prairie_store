<%= form_with model: [:admin, @product], local: true do |f| %>
  <div class="mb-3">
    <%= f.label :name %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :description %>
    <%= f.text_area :description, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :price %>
    <%= f.number_field :price, step: 0.01, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :stock_quantity %>
    <%= f.number_field :stock_quantity, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :category_id, "Category" %>
    <%= f.collection_select :category_id, Category.all, :id, :name, { prompt: "Select category" }, class: "form-select" %>
  </div>

  <%= f.submit class: "btn btn-success" %>
<% end %>